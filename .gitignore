/services/helper/target/
#libclash
/libclash/

#jniLibs
# core/src/main/jniLibs is fully generated by `setup.dart` (libclash + cgo
# headers). It must stay ignored — committing it pollutes the repo with
# 40+ MB of regenerated artefacts on every core update.
/android/core/src/main/jniLibs/

# app/src/main/jniLibs holds the embedded ParazitX relay binary
# (libparazitx-relay.so), built out of tree from the parazitx repo
# (see docs/parazitx/relay-build.md) and copied in. The directory is
# tracked so release APKs ship the binary even on a clean CI checkout
# — the relay build is not yet wired into setup.dart / CI.

# Signing keys (sensitive data)
/android/app/keystore.jks
/android/app/key.properties
/android/local.properties
*.jks
*.keystore
signing.properties

# Environment variables (contains sensitive data)
.env
*.local.sh

