<?xml version="1.0" encoding="utf-8"?>
<!--
  SECURITY: Exclude ALL app data from cloud backup and device-to-device
  transfer. VPN subscription URLs frequently contain auth tokens, and
  local profile YAMLs may embed proxy credentials. Users must log in
  fresh on a new device rather than have secrets silently migrated via
  Google's backup service.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
